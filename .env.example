# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key: Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: Settings → API → service_role. Server-side only — never NEXT_PUBLIC_.
# Used by admin routes and server actions that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Tenant ───────────────────────────────────────────────────────────────────
# Fixed UUID seeded by migration 011_rbac_roles.sql (SAGE POC tenant).
# Must match the row in public.tenants. Same value across dev and production
# unless you re-seed with a different UUID for the production tenant.
NEXT_PUBLIC_TENANT_ID=5ad3c505-285c-4cf1-8089-846367bf5bba

# ─── Sage backend (Railway) ───────────────────────────────────────────────────
# Server-side only — never NEXT_PUBLIC_. Browser calls /api/chat (Next.js route),
# which proxies to this URL server-to-server.
# Dev: http://localhost:8000  |  Deployed: https://<your-railway-service>.railway.app
SAGE_API_URL=http://localhost:8000

# Shared secret between Next.js /api/chat route and the Railway FastAPI service.
# Server-side only — never NEXT_PUBLIC_. Generate with: openssl rand -hex 32
SAGE_API_KEY=

# ─── Playwright E2E only (do not set in production) ───────────────────────────
# Exposes diagnostic response headers for E2E assertions. Leave unset outside CI.
# SAGE_EXPOSE_DIAGNOSTIC_HEADERS=true
