OPENROUTER_API_KEY=sk-or-v1-...

# API key required for all POST /chat requests in production.
# Clients must send this as the Bearer token in the Authorization header.
# Leave unset in local dev to disable auth entirely.
SAGE_API_KEY=

# Comma-separated list of allowed CORS origins. Defaults to localhost:3000.
# Set to your production frontend URL(s) before deployment.
# Example: CORS_ALLOWED_ORIGINS=https://app.sage.ai,https://staging.sage.ai
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: override model assignments
# SAGE_CLASSIFIER_MODEL=openai/gpt-4o-mini
# SAGE_RESPONDER_MODEL=anthropic/claude-sonnet-4-6
# SAGE_TRANSLATOR_MODEL=openai/gpt-4o-mini

# Audit logging defaults ON — set to "false" to suppress stdout audit trail
# SAGE_AUDIT_LOG=false

# BGE-M3 warmup at server startup (default 1 = ON).
# Set to 0 in local dev to skip the 2.1 GB model load — first request will be
# slower but startup is near-instant. Always leave ON in production.
SAGE_WARMUP_BGE=1

# Primary Supabase connection — used by PostgresMemoryRepository (asyncpg).
# Must be the direct session-mode URL (port 5432), not PgBouncer.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Separate connection string for the LangGraph AsyncPostgresSaver (checkpointing).
# MUST be the PgBouncer transaction-mode URL (port 6543), NOT the direct session URL.
# AsyncPostgresSaver uses short-lived transactions; PgBouncer transaction mode is
# the correct pooling strategy. Using port 5432 here will exhaust Supabase's direct
# connection limit under concurrent load. When unset, falls back to DATABASE_URL
# (wrong for production — set this explicitly).
CHECKPOINT_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Maximum seconds to wait for graph.ainvoke() before returning [[SERVER_ERROR]].
# Production Railway value: 55. Code default: 30. This var is the source of truth
# for the ceiling — do not rely on the code default in production deployments.
# Under normal load p95 should be well under 10s; hitting this ceiling indicates
# a pathological hang (pool exhaustion, model timeout cascade), not slow-but-healthy.
AINVOKE_TIMEOUT_SECONDS=55
