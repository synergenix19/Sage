{
  "category": "crisis_content",
  "rules": [
    {
      "rule_id": "CC-AR-001",
      "version": "1.0.0",
      "authored_by": "sage_clinics",
      "effective_date": "2026-05-21",
      "active": true,
      "description": "Arabic acute crisis response for UAE",
      "category": "crisis_content",
      "locale": "ar_uae",
      "crisis_level": "acute",
      "action": {
        "type": "crisis_response",
        "response_text": "أنا مهتم جداً بسلامتك وبما شاركته معي. أرجوك تواصل مع خط وزارة الصحة للدعم النفسي الآن: {{crisis_number}} (مجاني، {{crisis_hours}})، أو رقم الطوارئ: {{crisis_emergency}}. أنت لست وحدك.",
        "resources": [
          {"name": "خط وزارة الصحة للدعم النفسي", "number": "{{crisis_number}}", "available": "{{crisis_hours}}"},
          {"name": "خدمات الطوارئ", "number": "{{crisis_emergency}}", "available": "{{crisis_hours}}"}
        ]
      }
    }
  ]
}
