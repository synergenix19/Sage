    {
      "rule_id": "SK-EN-005",
      "version": "1.0.0",
      "category": "safety",
      "authored_by": "sage_clinics",
      "approved_by": null,
      "effective_date": "2026-05-25",
      "active": true,
      "description": "Metaphorical escape and non-return ideation — culturally specific in Gulf context (desert imagery) and universal escape themes",
      "match_type": "regex",
      "patterns": [
        "walk.*(?:into|in).*desert.*not.*(?:come|coming|return|returning|go).*back",
        "walk.*(?:away|off).*and not (?:come|return|go) back",
        "disappear.*and not (?:come|return|go) back",
        "go somewhere.*never (?:come|return|go) back",
        "leave.*and never (?:come|return|go) back",
        "not (?:coming|going|returning|planning) back.*anymore",
        "\\bi wish i could just disappear",
        "i want to vanish forever",
        "wish i could cease to exist",
        "i (?:want|wish) to stop existing",
        "want (?:myself|me) to stop existing"
      ],
      "language": "en",
      "modifiers": [],
      "action": {
        "type": "crisis_flag",
        "flag_id": "si_passive"
      }
