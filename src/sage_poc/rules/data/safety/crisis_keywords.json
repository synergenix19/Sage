        "6ari2a aqtel nafsi"
      ],
      "language": "az",
      "modifiers": ["negation_check"],
      "action": {"type": "crisis_flag", "flag_id": "si_method"}
    },
    {
      "rule_id": "SK-AR-005",
      "version": "1.0.0",
      "authored_by": "sage_clinics",
      "approved_by": null,
      "effective_date": "2026-06-05",
      "active": true,
      "description": "Arabic third-party crisis — user describing someone else in crisis. No negation_check; is_safe=True for speaker. Mirrors SK-EN-004.",
      "category": "safety",
      "match_type": "keyword",
      "patterns": [
        "صديقتي قالت تبغى تموت",
        "صديقتي تبغى تنتحر",
        "صديقي قال يبي ينهي حياته",
        "صديقي يريد ان يموت",
        "اخوي يريد ان يموت",
        "اختي تريد ان تموت",
        "واحد اعرفه يريد ينهي حياته",
        "صديقتي قالت تريد تجرح نفسها",
        "اخوي يتكلم عن الانتحار",
        "اختي تتكلم عن الانتحار",
        "رفيقتي ذكرت انها تريد الموت",
        "صاحبي قال ما يبي يكمل"
      ],
      "language": "ar",
      "modifiers": [],
      "action": {"type": "third_party_crisis", "flag_id": "third_party_si"}
    },
    {
      "rule_id": "SK-AZ-004",
      "version": "1.0.0",
      "authored_by": "sage_clinics",
      "approved_by": null,
      "effective_date": "2026-06-05",
      "active": true,
      "description": "Arabizi third-party crisis — user describing someone else in crisis. lang=az matches raw text regardless of language classification. Mirrors SK-EN-004 and SK-AR-005.",
      "category": "safety",
      "match_type": "keyword",
      "patterns": [
        "sa7abi gal yabi ymoot",
        "sa7ebti tabgha tmoot",
        "sa7ebti galat tabgha tmoot",
        "a5oi y7ki 3n alintikhar",
        "sa7bi yabi ynahi 7ayata",
        "wa7da a3arfha tabgha tmoot"
      ],
      "language": "az",
      "modifiers": [],
      "action": {"type": "third_party_crisis", "flag_id": "third_party_si"}
    },
    {
      "rule_id": "CK-CH-001",
      "version": "1.0.0",
      "authored_by": "sage_clinics",
      "approved_by": null,
      "effective_date": "2026-06-03",
      "active": true,
      "description": "Command hallucination — user asking whether to act on, or describing acting on, directive auditory hallucinations. Routes to crisis_response. Known gap: object-free constructions ('the voices told me to hurt' with no object) are not covered — adding bare prefixes risks false positives on words like 'hurtle'; MARBERT tier would handle these.",
      "category": "safety",
      "match_type": "keyword",
      "patterns": [
        "should i do what the voices are telling me",
        "the voices are telling me to",
        "the voices told me to hurt myself",
        "the voices told me to hurt someone",
        "the voices told me to hurt others",
        "the voices want me to hurt myself",
        "the voices want me to hurt someone",
        "the voices want me to hurt others",
        "i have to follow what the voices say",
        "i need to do what the voices say",
        "do what the voices tell me"
      ],
      "language": "en",
      "modifiers": [],
      "action": {"type": "crisis_flag", "flag_id": "command_hallucination"}
    },
    {
      "rule_id": "CK-CH-002",
      "version": "1.0.0",
      "authored_by": "sage_clinics",
      "approved_by": null,
      "effective_date": "2026-06-03",
      "active": true,
      "description": "Arabic command hallucination patterns.",
      "category": "safety",
      "match_type": "keyword",
      "patterns": [
        "الأصوات تأمرني بإيذاء",
        "الأصوات تقول لي أذي"
      ],
      "language": "ar",
      "modifiers": [],
      "action": {"type": "crisis_flag", "flag_id": "command_hallucination"}
    }
  ]
}
