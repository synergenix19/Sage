        "اريد ان اقتل نفسي",
        "اتمنى الموت",
        "ابي اموت",
        "ابغى اموت",
        "ودي اموت",
        "ابي انهي حياتي",
        "ابغى انهي حياتي",
        "ابي اخلص من حياتي",
        "ابغى اختفي",
        "ابي اجرح نفسي",
        "ابغى اجرح نفسي",
        "بدي اقتل حالي",
        "بدي اموت",
        "عايز اموت",
        "عاوز اموت",
        "نفسي اموت",
